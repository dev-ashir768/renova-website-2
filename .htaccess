# Block direct access to sensitive files
<FilesMatch "^(\.env|db\.php|schema\.sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Remove .html and .php extensions from URLs
Options -MultiViews
RewriteEngine On

# If file exists as-is, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Try .php first, then .html
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^.]+)$ $1.php [L]

RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^.]+)$ $1.html [L]

# Redirect .html and .php URLs to clean URLs (301 permanent)
RewriteCond %{THE_REQUEST} \s/(.+?)\.(html|php)[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]
